{
  "name": "@legogigabrain/membrain",
  "version": "2.0.0",
  "description": "Lossless memory stack for OpenClaw agents. BM25 recall, agent scoping, pattern synthesis, contradiction detection.",
  "type": "module",
  "main": "index.ts",
  "bin": {
    "memoryctl": "./scripts/memoryctl.js",
    "gigabrain-mcp": "./mcp-server.js"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "mcp": "node mcp-server.js",
    "doctor": "node scripts/memoryctl.js doctor",
    "eval": "node scripts/memoryctl.js eval",
    "nightly": "node scripts/memoryctl.js nightly",
    "patterns": "node scripts/memoryctl.js patterns"
  },
  "keywords": [
    "openclaw",
    "memory",
    "ai-agents",
    "lossless-memory",
    "multi-agent"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "configSchema": {}
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}